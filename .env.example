# ── Base de données (Neon Postgres) ─────────────────────────────────────────
# URL poolée pour l'app (driver neon-http) :
DATABASE_URL=postgres://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/kyb?sslmode=require
# URL directe non-poolée pour migrations & enrich transactionnel (recommandé) :
DATABASE_URL_UNPOOLED=postgres://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/kyb?sslmode=require

# ── Mode démo ────────────────────────────────────────────────────────────────
# true (défaut) → les connecteurs renvoient des fixtures locales (zéro clé requise).
NEXT_PUBLIC_DEMO_MODE=true

# ── INSEE Sirene (connecteur RÉEL) ───────────────────────────────────────────
# Compte sur https://portail-api.insee.fr/ → souscrire l'app à « API Sirene (V3.11) » → générer la clé.
INSEE_SIRENE_API_KEY=
INSEE_SIRENE_BASE_URL=https://api.insee.fr/api-sirene/3.11
# Le nom du header est figé dans le code (X-INSEE-Api-Key-Integration) ; vérifier la casse sur le portail.

# ── BODACC (connecteur RÉEL, sans clé) ───────────────────────────────────────
BODACC_BASE_URL=https://bodacc-datadila.opendatasoft.com/api/explore/v2.1
# Clé Opendatasoft optionnelle pour relever les limites de débit :
BODACC_API_KEY=

# ── INPI / RNE (STUB en MVP1 — non branché à l'API réelle) ───────────────────
INPI_USERNAME=
INPI_PASSWORD=

# ── DG Trésor – Registre national des gels (API publique ; mock par défaut) ──
TRESOR_GELS_ENABLED=false
TRESOR_GELS_BASE_URL=https://gels-avoirs.dgtresor.gouv.fr/ApiPublic/api/v1
